# ══════════════════════════════════════════════════════════════════════════════
# DTU Rakshak — Edge Device .env Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values before running ai_service.py.
# Each edge instance (camera) gets its own copy of the model/ folder + .env.
# ══════════════════════════════════════════════════════════════════════════════

# ── Backend URLs ─────────────────────────────────────────────────────────────
BACKEND_SCAN_URL=http://<backend-host>/api/v1/scan
BACKEND_CAMERA_URL=http://<backend-host>/api/v1/cameras

# ── Shared secret (must match EDGE_API_KEY in backend .env) ──────────────────
EDGE_API_KEY=change-me-use-a-long-random-secret

# ── Camera identity ───────────────────────────────────────────────────────────
# Get this UUID from the backend after registering the camera via POST /api/v1/cameras
# Leave blank to run in image-only mode (Postman testing without a live camera)
CAMERA_ID=

# ── Camera source ─────────────────────────────────────────────────────────────
# "0"              → first USB webcam
# "1", "2"...      → second, third USB webcam
# rtsp://ip/stream → IP/RTSP camera
# /path/video.mp4  → local video file (for Postman / offline testing)
CAMERA_SOURCE=0

# Loop a video file when it ends (ignored for live cameras)
VIDEO_LOOP=false

# ── Camera metadata ───────────────────────────────────────────────────────────
# These values are sent with every scan payload so the backend has full context.
# Must match what is stored in the DB for this camera.
CAMERA_LOCATION=Gate-A Main Entrance
CAMERA_TYPE=ENTRY        # ENTRY | EXIT | BOTH | INTERIOR
CAMERA_LAT=28.7041
CAMERA_LONG=77.1025

# ── Performance ───────────────────────────────────────────────────────────────
TARGET_FPS=20            # YOLO frames / sec
FRAME_SKIP=1             # process every Nth frame (raise on slow hardware)
OCR_WORKERS=1            # parallel OCR threads (raise to 2 with CUDA)
RTSP_RECONNECT_DELAY=5   # seconds before RTSP reconnect attempt
MJPEG_QUALITY=60         # JPEG quality for /stream preview

# ── Edge Redis dedup ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
IN_FRAME_TTL_SEC=3       # grace window while vehicle is in frame
SENT_TTL_SEC=120         # suppress re-sends for same plate within 2 min

# ── Heartbeat ─────────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=60    # seconds between alive pings to backend

# ── Model tuning ─────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.35
EXPAND_PADDING=8
