generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Admin / User ─────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  isVerified   Boolean  @default(false)
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Registered Vehicle (authorised sticker holders) ──────────────────────────
model Vehicle {
  id          String   @id @default(uuid())
  name        String
  fathersName String
  dept        String
  dateOfIssue DateTime
  vehicleType String              // "2W" | "4W" | "Heavy" | "Electric"
  stickerNo   String   @unique
  vehicleNo   String   @unique
  mobileNo    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs EntryExitLog[]

  @@map("vehicles")
}

// ── Campus Camera ─────────────────────────────────────────────────────────────
model Camera {
  id             String @id @default(uuid())
  lat            Float
  long           Float
  cameraType     String  // "ENTRY" | "EXIT" | "SIGHTING"
  cameraLocation String

  createdAt DateTime @default(now())

  logs      EntryExitLog[]
  sightings Sighting[]
  alerts    Alert[]

  @@map("cameras")
}

// ── Entry / Exit / Sighting Log ───────────────────────────────────────────────
// logType:
//   ENTRY    – vehicle entered campus (gate camera, no prior open log)
//   EXIT     – vehicle exited campus  (gate camera, closes an ENTRY log)
//   SIGHTING – vehicle spotted at interior/area camera (no entry/exit impact)
//
// vehicleNo  – raw plate string, ALWAYS present (no FK — unregistered vehicles must be stored too)
// vehicleId  – FK to vehicles.id, only set when the vehicle is registered/authorized

model EntryExitLog {
  id       String @id @default(uuid())
  cameraId String
  camera   Camera @relation(fields: [cameraId], references: [id])

  vehicleNo String   // plate number as received from edge device (e.g. "DL3CAF0001")
  vehicleId String?  // FK → vehicles.id, null for unregistered vehicles
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  logType         String    @default("ENTRY")  // "ENTRY" | "EXIT" | "ORPHAN"
  ocrConfidence   Float?                        // OCR (Text reading) confidence
  modelConfidence Float?                        // YOLO (Car detection) confidence
  rawPlate        String                        // raw OCR string
  entryTime       DateTime  @default(now())
  exitTime        DateTime?                     // null unless EXIT
  vehicleDuration Int?                          // seconds on campus (gate cameras only)
  isAuthorized    Boolean   @default(false)     // true if vehicle exists in vehicles table
  vehicleCategory String    @default("UNVERIFIED")
  
  createdAt DateTime @default(now())

  sightings Sighting[]

  @@map("entry_exit_logs")
}

// ── Sighting Log (Interior Tracking) ─────────────────────────────────────────
model Sighting {
  id         String @id @default(uuid())
  
  sessionId  String
  session    EntryExitLog @relation(fields: [sessionId], references: [id])
  
  cameraId   String
  camera     Camera       @relation(fields: [cameraId], references: [id])
  
  timestamp       DateTime @default(now())
  ocrConfidence   Float?   // OCR (Text reading) confidence
  modelConfidence Float?   // YOLO (Car detection) confidence
  
  createdAt  DateTime @default(now())

  @@map("sightings")
}

// ── Alert & Anomaly Tracking ─────────────────────────────────────────────────
model Alert {
  id          String   @id @default(uuid())
  
  alertType   String   // e.g., "UNAUTHORIZED_ENTRY", "OVERSTAY", "EXIT_WITHOUT_ENTRY", "ORPHAN_SIGHTING", "CONCURRENT_ENTRY_OVERWRITE"
  severity    String   @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  status      String   @default("OPEN")   // "OPEN" | "ACKNOWLEDGED" | "RESOLVED"
  
  description String   // Human-readable message explaining the anomaly
  
  vehicleNo   String?  // The raw plate number involved
  
  cameraId    String?  
  camera      Camera?  @relation(fields: [cameraId], references: [id])
  
  logId       String?  // Can tie back to an EntryExitLog if the alert generated during a log event
  
  resolvedBy  String?  // Admin User ID who resolved the alert
  resolvedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("alerts")
}
