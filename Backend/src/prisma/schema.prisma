generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Admin / User ─────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  isVerified   Boolean  @default(false)
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Registered Vehicle (authorised sticker holders) ──────────────────────────
//
// Sensitive fields are stored encrypted (AES-256-GCM) + hashed (SHA-256):
//   vehicleNo   → raw plate stored as JSON-encoded cipher blob
//   vehicleNoHash → SHA-256(normalised plate) — used for all lookups/joins (@unique)
//   mobileNo    → raw phone stored as JSON-encoded cipher blob
//   mobileNoHash → SHA-256(normalised phone) — indexed for potential future queries
//
// Decryption happens in crypto.util.js → decryptVehicle().
// The frontend never receives encrypted blobs.

model Vehicle {
  id          String   @id @default(uuid())
  name        String
  fathersName String
  dept        String
  dateOfIssue DateTime
  vehicleType String              // "2W" | "4W" | "Heavy" | "Electric"
  stickerNo   String   @unique

  vehicleNo     String            // AES-256-GCM encrypted blob (JSON: {iv, content, tag})
  vehicleNoHash String?  @unique  // SHA-256(normalised plate) — all lookups use this

  mobileNo     String             // AES-256-GCM encrypted blob (JSON: {iv, content, tag})
  mobileNoHash String?            // SHA-256(normalised phone)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs EntryExitLog[]

  @@index([vehicleNoHash])
  @@map("vehicles")
}

// ── Campus Camera ─────────────────────────────────────────────────────────────
model Camera {
  id             String @id @default(uuid())
  lat            Float
  long           Float
  cameraType     String  // "ENTRY" | "EXIT" | "INTERIOR"
  cameraLocation String

  createdAt DateTime @default(now())

  logs      EntryExitLog[]
  sightings Sighting[]
  alerts    Alert[]

  @@map("cameras")
}

// ── Entry / Exit Log ──────────────────────────────────────────────────────────
// logType:
//   ENTRY    – vehicle entered campus (gate camera, no prior open log)
//   EXIT     – vehicle exited campus  (gate camera, closes an ENTRY log)
//   ORPHAN   – vehicle spotted inside campus but missing an ENTRY log.
//              (Acts as a dummy session so interior Sightings have a valid 
//              Foreign Key, whilst instantly triggering an ORPHAN_SIGHTING safety alert)
//
// vehicleNo     – raw plate string from edge device (kept as audit trail, not encrypted)
// vehicleNoHash – SHA-256(normalised plate) — used for filtering/joining by plate
// vehicleId     – FK to vehicles.id, only set when the vehicle is registered/authorized

model EntryExitLog {
  id       String @id @default(uuid())
  cameraId String
  camera   Camera @relation(fields: [cameraId], references: [id])

  vehicleNo     String   // plate number as received from edge device (e.g. "DL3CAF0001")
  vehicleNoHash String?  // SHA-256(normalised plate) — for plate-based queries
  vehicleId     String?  // FK → vehicles.id, null for unregistered vehicles
  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id])

  logType         String    @default("ENTRY")  // "ENTRY" | "EXIT" | "ORPHAN"
  ocrConfidence   Float?                        // OCR (Text reading) confidence
  modelConfidence Float?                        // YOLO (Car detection) confidence
  rawPlate        String                        // raw OCR string
  entryTime       DateTime  @default(now())
  exitTime        DateTime?                     // null unless EXIT
  vehicleDuration Int?                          // seconds on campus (gate cameras only)
  isAuthorized    Boolean   @default(false)     // true if vehicle exists in vehicles table
  
  createdAt DateTime @default(now())

  sightings Sighting[]
  alerts    Alert[]

  @@index([vehicleNoHash])
  @@map("entry_exit_logs")
}

// ── Sighting Log (Interior Tracking) ─────────────────────────────────────────
model Sighting {
  id         String @id @default(uuid())
  
  sessionId  String
  session    EntryExitLog @relation(fields: [sessionId], references: [id])
  
  cameraId   String
  camera     Camera       @relation(fields: [cameraId], references: [id])
  
  timestamp       DateTime @default(now())
  ocrConfidence   Float?   // OCR (Text reading) confidence
  modelConfidence Float?   // YOLO (Car detection) confidence
  rawPlate        String   // raw OCR string
  
  createdAt  DateTime @default(now())

  @@map("sightings")
}

// ── Alert & Anomaly Tracking ─────────────────────────────────────────────────
model Alert {
  id          String   @id @default(uuid())
  
  alertType   String   // e.g., "UNAUTHORIZED_ENTRY", "OVERSTAY", "EXIT_WITHOUT_ENTRY", "ORPHAN_SIGHTING", "CONCURRENT_ENTRY_OVERWRITE"
  status      String   @default("OPEN")   // "OPEN" | "ACKNOWLEDGED" | "RESOLVED"
  
  description String   // Human-readable message explaining the anomaly
  
  rawPlate    String   // raw OCR string from edge device
  
  cameraId    String?  
  camera      Camera?  @relation(fields: [cameraId], references: [id])
  
  logId       String   // Strictly tied to the EntryExitLog session
  log         EntryExitLog @relation(fields: [logId], references: [id])
  
  resolvedBy  String?  // Admin User ID who resolved the alert
  resolvedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("alerts")
}
